# Copy this file to .env and fill in your own CS2 server's values.
# .env is gitignored — never commit real credentials.
# Used by the tools/deploy_*.py and tools/rcon.py deploy scripts.

# --- FTP (file upload to your game server host) ---
FTP_HOST=your-host.example.net
FTP_USER=your_ftp_user
FTP_PASS=your_ftp_password

# --- RCON (remote console of your CS2 server) ---
RCON_HOST=your.server.address
RCON_PORT=27015
RCON_PASS=your_rcon_password

# --- dathost HTTP API (optional) ---
# Only needed for deploy_hard.py's clean stop/start restart.
# Leave blank to fall back to a soft css_plugins reload.
DATHOST_EMAIL=
DATHOST_PASSWORD=
DATHOST_SERVER_ID=
